{
	"opts": {
		"encoding": "utf8",
		"destination": "./build/docs/",
		"recurse": true,
		"template": "./node_modules/@alphanull/jsdoc-vision-theme"
	},
	"plugins": [
		"plugins/markdown"
	],
	"markdown": {
		"idInHeadings": true
	},
	"recurseDepth": 10,
	"source": {
		"includePattern": ".+\\.js(doc|x)?$",
		"excludePattern": "(^|\\/|\\\\)_"
	},
	"sourceType": "module",
	"tags": {
		"allowUnknownTags": false,
		"dictionaries": [
			"jsdoc",
			"closure"
		]
	},
	"templates": {
		"cleverLinks": false,
		"monospaceLinks": false
	}
}